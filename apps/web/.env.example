# apps/web — переменные окружения
# Скопируй в .env.local для локальной разработки.
# .env.local в .gitignore — не коммить реальные значения.

# ── Сейчас (статика, CMS не подключена) ────────────────────────────────────
# Переменных для прода нет: сайт output:"export", всё захардкожено в site.ts.

# ── Фаза 2: Sanity CMS (ADR-0001) ──────────────────────────────────────────
# После подключения Sanity раскомментировать:
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# SANITY_API_TOKEN=                   # read-only для ISR/SSG; НЕ коммить
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# ── Фаза 3: аналитика ──────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_YM_COUNTER=XXXXXXXX

# ── Фаза 3: email/CRM для лидов ────────────────────────────────────────────
# Сейчас лиды уходят через wa.me-ссылку (WhatsApp).
# Когда добавим серверную обработку форм:
# LEAD_EMAIL_TO=karaokeshop2015@gmail.com
# RESEND_API_KEY=                     # или другой провайдер
