{
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": {
        "$value": "Manrope",
        "$description": "Основной UI-шрифт"
      },
      "display": {
        "$value": "Unbounded",
        "$description": "Заголовочный / брендовый шрифт"
      }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "12px" },
      "sm": { "$value": "14px" },
      "base": { "$value": "16px" },
      "lg": { "$value": "18px" },
      "xl": { "$value": "20px" },
      "2xl": { "$value": "24px" },
      "3xl": { "$value": "30px" },
      "4xl": { "$value": "36px" },
      "5xl": { "$value": "48px" }
    },
    "lineHeight": {
      "$type": "number",
      "tight": { "$value": 1.25, "$description": "Заголовки (tracking-tight)" },
      "snug": { "$value": 1.375 },
      "normal": { "$value": 1.5, "$description": "Основной текст" },
      "relaxed": { "$value": 1.625 }
    },
    "letterSpacing": {
      "$type": "dimension",
      "tight": { "$value": "-0.025em", "$description": "tracking-tight (Hero h1)" },
      "normal": { "$value": "0em" }
    }
  }
}
